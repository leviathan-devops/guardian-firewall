#!/bin/bash
#===============================================================================
# GUARDIAN v2.0 - Safe File Protection for AI Agents
#===============================================================================
# Protects AI agent configuration files from accidental modification.
#
# CRITICAL: This version includes USER SOVEREIGNTY protections.
# The human user ALWAYS has final control over their device.
#
# Golden Rules:
# 1. User shell configs are NEVER protected
# 2. Emergency override ALWAYS works
# 3. Recovery instructions exist OUTSIDE protected area
#===============================================================================

set -e

#===============================================================================
# CONFIGURATION
#===============================================================================

GUARDIAN_DIR="$HOME/.guardrails"
APPROVAL_QUEUE="$GUARDIAN_DIR/approval_queue"
APPROVAL_LOG="$GUARDIAN_DIR/approval_log"
RECOVERY_FILE="$HOME/GUARDIAN_RECOVERY_INSTRUCTIONS.txt"

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
NC='\033[0m'

#===============================================================================
# PROTECTED FILES - AGENT SPECIFIC ONLY
#===============================================================================
# IMPORTANT: User files (.bashrc, .profile, etc.) are NEVER protected.
# This ensures the human user always has control over their device.

PROTECTED_FILES=(
    "$HOME/.qwen/settings.json"
    "$HOME/.qwen/config.json"
    "$HOME/.qwen/QWEN.md"
)

# Guardian self-protection files
GUARDIAN_SELF_PROTECT=(
    "$GUARDIAN_DIR/guardian"
    "$GUARDIAN_DIR/bin/sudo"
    "$GUARDIAN_DIR/guardian-nlp.py"
    "$GUARDIAN_DIR/unlock-tracker.py"
)

#===============================================================================
# USER SOVEREIGNTY - FILES THAT ARE NEVER PROTECTED
#===============================================================================
# These files can NEVER be protected by Guardian, even if user tries.

USER_SOVEREIGN_PATTERNS=(
    ".bashrc"
    ".bash_aliases"
    ".bash_profile"
    ".bash_logout"
    ".profile"
    ".zshrc"
    ".zprofile"
    ".zshenv"
    ".zlogin"
    ".ssh"
    ".gnupg"
    ".config/autostart"
    ".config/systemd"
    ".local/share/systemd"
    ".pam_environment"
    ".xinitrc"
    ".xsession"
    ".xprofile"
)

#===============================================================================
# UTILITY FUNCTIONS
#===============================================================================

log_action() {
    local action="$1"
    local file="$2"
    local reason="${3:-}"
    local timestamp=$(date '+%Y-%m-%d %H:%M:%S')
    echo "$timestamp|$(whoami)|$action|$file|$reason" >> "$APPROVAL_LOG"
}

check_user_sovereignty() {
    local file="$1"
    local resolved=""
    
    # Resolve path
    if command -v realpath &>/dev/null; then
        resolved=$(realpath "$file" 2>/dev/null || echo "$file")
    else
        resolved="$file"
    fi
    
    # Check against sovereignty patterns
    for pattern in "${USER_SOVEREIGN_PATTERNS[@]}"; do
        if [[ "$resolved" == *"$pattern"* ]] || [[ "$resolved" == "$HOME/$pattern"* ]]; then
            return 0  # File is user sovereign
        fi
    done
    
    return 1  # File is not user sovereign
}

is_protected() {
    local file="$1"
    local attrs=$(/usr/bin/lsattr -d "$file" 2>/dev/null | cut -d' ' -f1 || echo "")
    
    if echo "$attrs" | grep -q 'i'; then
        return 0  # File is protected
    fi
    return 1  # File is not protected
}

#===============================================================================
# INITIALIZATION
#===============================================================================

guardian_init() {
    echo -e "${CYAN}╔══════════════════════════════════════════════════════════╗${NC}"
    echo -e "${CYAN}║        GUARDIAN v2.0 - Safe File Protection              ║${NC}"
    echo -e "${CYAN}╚══════════════════════════════════════════════════════════╝${NC}"
    echo ""
    
    # Create directories
    mkdir -p "$GUARDIAN_DIR"
    mkdir -p "$GUARDIAN_DIR/backups"
    mkdir -p "$GUARDIAN_DIR/approval_queue"
    mkdir -p "$GUARDIAN_DIR/logs"
    mkdir -p "$GUARDIAN_DIR/bin"
    
    # Initialize approval log
    if [ ! -f "$APPROVAL_LOG" ]; then
        echo "timestamp|user|action|file|reason" > "$APPROVAL_LOG"
    fi
    
    # Install emergency override
    install_emergency_override
    
    # Install recovery instructions
    install_recovery_instructions
    
    # Protect agent files
    echo -e "${BLUE}[*] Protecting agent configuration files...${NC}"
    
    for file in "${PROTECTED_FILES[@]}"; do
        if [ -f "$file" ]; then
            # Verify it's not user sovereign
            if check_user_sovereignty "$file"; then
                echo -e "${RED}  ⚠ SKIPPED (user sovereign): $file${NC}"
                continue
            fi
            
            /usr/bin/sudo chattr +i "$file" 2>/dev/null && \
                echo -e "${GREEN}  ✓ Protected: $file${NC}" || \
                echo -e "${YELLOW}  ⚠ Could not protect: $file${NC}"
        fi
    done
    
    # Protect guardian itself
    echo ""
    echo -e "${BLUE}[*] Protecting Guardian files...${NC}"
    
    for file in "${GUARDIAN_SELF_PROTECT[@]}"; do
        if [ -f "$file" ]; then
            /usr/bin/sudo chattr +i "$file" 2>/dev/null && \
                echo -e "${GREEN}  ✓ Protected: $file${NC}" || true
        fi
    done
    
    echo ""
    echo -e "${GREEN}✅ GUARDIAN initialized successfully${NC}"
    echo ""
    echo -e "${YELLOW}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
    echo -e "${YELLOW}  PROTECTED FILES (agents need approval):${NC}"
    for f in "${PROTECTED_FILES[@]}"; do
        echo -e "${YELLOW}    • $f${NC}"
    done
    echo ""
    echo -e "${GREEN}  USER SOVEREIGN FILES (always editable):${NC}"
    echo -e "${GREEN}    • ~/.bashrc, ~/.profile, ~/.zshrc${NC}"
    echo -e "${GREEN}    • ~/.ssh, ~/.gnupg${NC}"
    echo ""
    echo -e "${CYAN}  EMERGENCY OVERRIDE:${NC}"
    echo -e "${CYAN}    • guardian-emergency unlock-all${NC}"
    echo -e "${CYAN}    • ~/GUARDIAN_RECOVERY_INSTRUCTIONS.txt${NC}"
    echo -e "${YELLOW}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
    echo ""
}

#===============================================================================
# EMERGENCY OVERRIDE INSTALLATION
#===============================================================================

install_emergency_override() {
    local emergency_script="/usr/bin/guardian-emergency"
    
    echo -e "${BLUE}[*] Installing emergency override...${NC}"
    
    # Create the emergency script
    /usr/bin/sudo tee "$emergency_script" > /dev/null << 'EMERGENCY_SCRIPT'
#!/bin/bash
#===============================================================================
# GUARDIAN EMERGENCY OVERRIDE
#===============================================================================
# This command ALWAYS works for the human user.
# It is installed in /usr/bin/ so it works even if ~/.guardrails is broken.
#===============================================================================

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m'

case "${1:-}" in
    unlock-all)
        echo -e "${YELLOW}Unlocking all protected files...${NC}"
        
        # Unlock agent files
        for f in "$HOME/.qwen/settings.json" "$HOME/.qwen/config.json" "$HOME/.qwen/QWEN.md"; do
            if [ -f "$f" ]; then
                /usr/bin/sudo chattr -i "$f" 2>/dev/null && \
                    echo -e "${GREEN}  ✓ Unlocked: $f${NC}" || true
            fi
        done
        
        # Unlock guardian files
        for f in "$HOME/.guardrails/guardian" "$HOME/.guardrails/bin/sudo" \
                 "$HOME/.guardrails/guardian-nlp.py" "$HOME/.guardrails/unlock-tracker.py"; do
            if [ -f "$f" ]; then
                /usr/bin/sudo chattr -i "$f" 2>/dev/null && \
                    echo -e "${GREEN}  ✓ Unlocked: $f${NC}" || true
            fi
        done
        
        # CRITICAL: Also unlock any user files that might have been accidentally protected
        for f in "$HOME/.bashrc" "$HOME/.bash_aliases" "$HOME/.bash_profile" \
                 "$HOME/.profile" "$HOME/.zshrc" "$HOME/.zprofile"; do
            if [ -f "$f" ]; then
                attrs=$(/usr/bin/lsattr -d "$f" 2>/dev/null | cut -d' ' -f1 || echo "")
                if echo "$attrs" | grep -q 'i'; then
                    /usr/bin/sudo chattr -i "$f" 2>/dev/null && \
                        echo -e "${GREEN}  ✓ RECOVERED user file: $f${NC}" || true
                fi
            fi
        done
        
        echo ""
        echo -e "${GREEN}✅ All files unlocked${NC}"
        ;;
        
    disable)
        echo -e "${RED}Disabling Guardian entirely...${NC}"
        
        # Unlock everything
        /usr/bin/guardian-emergency unlock-all
        
        # Remove bash hooks from .bashrc
        if [ -f "$HOME/.bashrc" ]; then
            /usr/bin/sudo chattr -i "$HOME/.bashrc" 2>/dev/null || true
            sed -i '/guardrails\/bash_hooks/d' "$HOME/.bashrc" 2>/dev/null || true
            sed -i '/Guardian bash hooks/d' "$HOME/.bashrc" 2>/dev/null || true
            sed -i '/Guardian sudo wrapper/d' "$HOME/.bashrc" 2>/dev/null || true
        fi
        
        echo ""
        echo -e "${GREEN}✅ Guardian disabled${NC}"
        echo -e "${YELLOW}Run 'guardian init' to re-enable${NC}"
        ;;
        
    status)
        echo -e "${CYAN}═══════════════════════════════════════════════════════════${NC}"
        echo -e "${CYAN}             GUARDIAN STATUS CHECK                         ${NC}"
        echo -e "${CYAN}═══════════════════════════════════════════════════════════${NC}"
        echo ""
        
        echo -e "${BLUE}Protected Files:${NC}"
        for f in "$HOME/.qwen/settings.json" "$HOME/.qwen/config.json"; do
            if [ -f "$f" ]; then
                attrs=$(/usr/bin/lsattr -d "$f" 2>/dev/null | cut -d' ' -f1 || echo "----")
                if echo "$attrs" | grep -q 'i'; then
                    echo -e "  🔒 LOCKED:   $f"
                else
                    echo -e "  🔓 UNLOCKED: $f"
                fi
            fi
        done
        
        echo ""
        echo -e "${BLUE}User Sovereignty Check:${NC}"
        for f in "$HOME/.bashrc" "$HOME/.profile"; do
            if [ -f "$f" ]; then
                attrs=$(/usr/bin/lsattr -d "$f" 2>/dev/null | cut -d' ' -f1 || echo "----")
                if echo "$attrs" | grep -q 'i'; then
                    echo -e "  ${RED}⚠ LOCKED (should not be!): $f${NC}"
                else
                    echo -e "  ${GREEN}✓ User editable: $f${NC}"
                fi
            fi
        done
        
        echo ""
        echo -e "${BLUE}Guardian Files:${NC}"
        if [ -f "$HOME/.guardrails/guardian" ]; then
            attrs=$(/usr/bin/lsattr -d "$HOME/.guardrails/guardian" 2>/dev/null | cut -d' ' -f1 || echo "----")
            if echo "$attrs" | grep -q 'i'; then
                echo -e "  🔒 Protected: $HOME/.guardrails/guardian"
            else
                echo -e "  🔓 Unprotected: $HOME/.guardrails/guardian"
            fi
        fi
        ;;
        
    recover-user-files)
        echo -e "${YELLOW}Recovering all user files...${NC}"
        
        USER_FILES=(
            "$HOME/.bashrc"
            "$HOME/.bash_aliases"
            "$HOME/.bash_profile"
            "$HOME/.bash_logout"
            "$HOME/.profile"
            "$HOME/.zshrc"
            "$HOME/.zprofile"
            "$HOME/.zshenv"
            "$HOME/.zlogin"
        )
        
        for f in "${USER_FILES[@]}"; do
            if [ -f "$f" ]; then
                /usr/bin/sudo chattr -i "$f" 2>/dev/null && \
                    echo -e "${GREEN}  ✓ Recovered: $f${NC}" || true
            fi
        done
        
        echo ""
        echo -e "${GREEN}✅ All user files should now be editable${NC}"
        ;;
        
    *)
        echo ""
        echo -e "${YELLOW}╔══════════════════════════════════════════════════════════╗${NC}"
        echo -e "${YELLOW}║        GUARDIAN EMERGENCY OVERRIDE                       ║${NC}"
        echo -e "${YELLOW}╚══════════════════════════════════════════════════════════╝${NC}"
        echo ""
        echo "Usage: guardian-emergency <command>"
        echo ""
        echo "Commands:"
        echo "  unlock-all         Unlock all protected files"
        echo "  disable            Disable Guardian entirely"
        echo "  status             Check protection status"
        echo "  recover-user-files Force unlock user shell configs"
        echo ""
        echo -e "${GREEN}This command ALWAYS works for the human user.${NC}"
        echo -e "${GREEN}It uses /usr/bin/sudo directly to bypass any Guardian wrappers.${NC}"
        echo ""
        ;;
esac
EMERGENCY_SCRIPT
    
    /usr/bin/sudo chmod +x "$emergency_script"
    echo -e "${GREEN}  ✓ Emergency override installed: $emergency_script${NC}"
}

