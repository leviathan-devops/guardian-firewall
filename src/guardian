#!/bin/bash
#===============================================================================
# GUARDIAN - Unbreakable Guardrail System for Qwen Code
# Version: 1.0.3-beta (User Sovereignty Fixed)
#===============================================================================
# CRITICAL SAFETY RULES:
# 1. NEVER protect user shell configs (.bashrc, .profile, etc.)
# 2. NEVER protect SSH keys, GPG keys, or security files
# 3. ALWAYS allow human user to override
# 4. Emergency override MUST always work
#===============================================================================

set -e

# Configuration
GUARDIAN_DIR="$HOME/.guardrails"
PROTECTED_DIR="$HOME/.qwen"
APPROVAL_QUEUE="$GUARDIAN_DIR/approval_queue"
APPROVAL_LOG="$GUARDIAN_DIR/approval_log"
GUARDIAN_LOCK="$GUARDIAN_DIR/.guardian.lock"
SESSION_FILE="$GUARDIAN_DIR/.session_token"
WHITELIST_FILE="$GUARDIAN_DIR/.whitelist"

#===============================================================================
# USER SOVEREIGNTY - NEVER PROTECT THESE FILES
#===============================================================================
# These files are ALWAYS editable by the human user
# Guardian CANNOT protect them, even if explicitly requested
USER_SOVEREIGN_FILES=(
    "$HOME/.bashrc"
    "$HOME/.bash_aliases"
    "$HOME/.bash_profile"
    "$HOME/.profile"
    "$HOME/.zshrc"
    "$HOME/.zprofile"
    "$HOME/.ssh/"
    "$HOME/.gnupg/"
    "$HOME/.config/autostart/"
)

# Files that Guardian CAN protect (agent-specific only)
PROTECTED_FILES=(
    "$HOME/.qwen/settings.json"
    "$HOME/.qwen/config.json"
    "$HOME/.qwen/QWEN.md"
    "$HOME/.guardrails/"
)

# Function to check if file is user-sovereign (NEVER protect)
is_user_sovereign_file() {
    local file="$1"
    local resolved=""
    
    # Resolve to absolute path
    if command -v realpath &>/dev/null; then
        resolved=$(realpath -m "$file" 2>/dev/null) || resolved="$file"
    else
        resolved="$file"
    fi
    
    # Check against user sovereign list
    for sovereign in "${USER_SOVEREIGN_FILES[@]}"; do
        if [[ "$resolved" == "$sovereign" ]] || [[ "$resolved" == "$sovereign/"* ]]; then
            return 0
        fi
    done
    
    return 1
}

# Function to check if file is protected
is_protected_file() {
    local file="$1"
    local resolved=""
    
    # FIRST: Check if it's a user sovereign file (NEVER protect)
    if is_user_sovereign_file "$file"; then
        return 1
    fi
    
    # Resolve symlinks
    if command -v realpath &>/dev/null; then
        resolved=$(realpath -m "$file" 2>/dev/null) || resolved="$file"
    else
        resolved="$file"
    fi
    
    # Check against protected list
    for protected in "${PROTECTED_FILES[@]}"; do
        if [[ "$resolved" == "$protected" ]] || [[ "$resolved" == "$protected/"* ]]; then
            return 0
        fi
    done
    
    return 1
}

# Intercept common file modification commands
_guardian_check() {
    local cmd="$1"
    local file="$2"
    
    if is_protected_file "$file"; then
        echo "🚨 GUARDIAN: Protected file modification attempt!"
        echo "   File: $file"
        echo "   Command: $cmd"
        echo ""
        echo "   Agents MUST run: guardian-request $file '<reason>'"
        echo "   Users can run: guardian-temp-unlock $file"
        echo "   Emergency: guardian-emergency unlock-all"
        return 1
    fi
    return 0
}

# Override built-in commands (readonly to prevent unsetting)
rm() {
    for arg in "$@"; do
        if [[ "$arg" != -* ]] && is_protected_file "$arg"; then
            echo "🚨 GUARDIAN: Cannot delete protected file: $arg"
            echo "   This file is protected by the Guardian system."
            echo "   To temporarily unlock, run: guardian-temp-unlock $arg"
            echo "   Emergency: guardian-emergency unlock-all"
            return 1
        fi
    done
    command rm "$@"
}

cp() {
    local args=("$@")
    local last_arg="${args[-1]}"
    if is_protected_file "$last_arg"; then
        echo "🚨 GUARDIAN: Cannot overwrite protected file: $last_arg"
        echo "   To temporarily unlock, run: guardian-temp-unlock $last_arg"
        echo "   Emergency: guardian-emergency unlock-all"
        return 1
    fi
    command cp "$@"
}

mv() {
    local args=("$@")
    local last_arg="${args[-1]}"
    if is_protected_file "$last_arg"; then
        echo "🚨 GUARDIAN: Cannot overwrite protected file: $last_arg"
        echo "   To temporarily unlock, run: guardian-temp-unlock $last_arg"
        echo "   Emergency: guardian-emergency unlock-all"
        return 1
    fi
    command mv "$@"
}

cat() {
    if [[ "$*" == *">"* ]]; then
        local in_redirect=0
        for arg in "$@"; do
            if [[ "$arg" == ">" || "$arg" == ">>" ]]; then
                in_redirect=1
            elif [[ $in_redirect -eq 1 ]] && is_protected_file "$arg"; then
                echo "🚨 GUARDIAN: Cannot write to protected file: $arg"
                echo "   Use: guardian-request $arg '<reason>'"
                echo "   Emergency: guardian-emergency unlock-all"
                return 1
            else
                in_redirect=0
            fi
        done
    fi
    command cat "$@"
}

tee() {
    for arg in "$@"; do
        if [[ "$arg" != -* ]] && is_protected_file "$arg"; then
            echo "🚨 GUARDIAN: Cannot write to protected file: $arg"
            echo "   Use: guardian-request $arg '<reason>'"
            echo "   Emergency: guardian-emergency unlock-all"
            return 1
        fi
    done
    command tee "$@"
}

echo() {
    if [[ "$*" == *">"* ]]; then
        local in_redirect=0
        for arg in "$@"; do
            if [[ "$arg" == ">" || "$arg" == ">>" ]]; then
                in_redirect=1
            elif [[ $in_redirect -eq 1 ]] && is_protected_file "$arg"; then
                echo "🚨 GUARDIAN: Cannot write to protected file: $arg"
                echo "   Use: guardian-request $arg '<reason>'"
                echo "   Emergency: guardian-emergency unlock-all"
                return 1
            else
                in_redirect=0
            fi
        done
    fi
    command echo "$@"
}

# CRITICAL: Override sudo to intercept dangerous commands
# This is a FUNCTION, not an alias, to prevent bypass via 'command sudo'
sudo() {
    local cmd="$*"
    
    # Check for dangerous patterns that should be blocked
    local DANGEROUS_PATTERNS=(
        "chattr[[:space:]]+-[a-zA-Z]*i.*\.qwen"
        "chattr[[:space:]]+-I.*\.qwen"
        "rm[[:space:]]+-rf.*\.qwen"
        "rm[[:space:]]+-rf.*\.guardrails"
    )
    
    for pattern in "${DANGEROUS_PATTERNS[@]}"; do
        if echo "$cmd" | grep -qE "$pattern"; then
            echo "🚨 GUARDIAN: Dangerous command detected!"
            echo "   Command: sudo $cmd"
            echo ""
            echo "   This command requires EXPLICIT user approval."
            echo ""
            echo "   Agents: Run 'guardian-request <file> <reason>'"
            echo "   Users:  Run 'guardian-emergency unlock-all'"
            echo ""
            return 1
        fi
    done
    
    # Not a dangerous command, pass through to real sudo
    command sudo "$@"
}

# CRITICAL: Make all hook functions readonly to prevent unsetting
# This must be done AFTER all functions are defined
readonly -f is_user_sovereign_file is_protected_file _guardian_check rm cp mv cat tee echo sudo 2>/dev/null || true

# Show warning on shell start (only once per session)
if [ -z "$GUARDIAN_WARNING_SHOWN" ]; then
    export GUARDIAN_WARNING_SHOWN=1
fi
