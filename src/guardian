guardian_pending() {
    echo -e "${BLUE}Pending Requests:${NC}"
    
    local found=0
    shopt -s nullglob
    for request_file in "$APPROVAL_QUEUE"/*.request; do
        if [ -f "$request_file" ]; then
            found=1
            local id=$(grep "^REQUEST_ID:" "$request_file" | cut -d: -f2 | tr -d ' ')
            local file=$(grep "^FILE:" "$request_file" | cut -d: -f2-)
            local reason=$(grep "^REASON:" "$request_file" | cut -d: -f2-)
            
            echo ""
            echo -e "${CYAN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
            echo -e "${BLUE}ID:${NC} $id"
            echo -e "${BLUE}File:${NC} $file"
            echo -e "${BLUE}Reason:${NC} $reason"
        fi
    done
    
    if [ "$found" -eq 0 ]; then
        echo -e "${GREEN}No pending requests${NC}"
    fi
}

guardian_log() {
    local lines="${1:-20}"
    echo -e "${BLUE}Recent Guardian Activity:${NC}"
    tail -n "$lines" "$APPROVAL_LOG" 2>/dev/null || echo "No log found"
}

