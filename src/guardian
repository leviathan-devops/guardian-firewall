guardian_temp_unlock() {
    local file="$1"
    local duration="${2:-300}"
    
    if [ -z "$file" ]; then
        echo -e "${RED}❌ Usage: guardian temp-unlock <file> [duration_seconds]${NC}"
        return 1
    fi
    
    # Resolve path
    file=$(realpath "$file" 2>/dev/null || echo "$file")
    
    # Check user sovereignty
    if check_user_sovereignty "$file"; then
        echo -e "${GREEN}This file is user-sovereign. You can edit it without unlocking.${NC}"
        return 0
    fi
    
    echo -e "${YELLOW}Unlocking: $file${NC}"
    /usr/bin/sudo chattr -i "$file"
    
    # Track unlock
    if [ -f "$GUARDIAN_DIR/unlock-tracker.py" ]; then
        python3 "$GUARDIAN_DIR/unlock-tracker.py" add "$file" "$duration" 2>/dev/null
    fi
    
    echo -e "${GREEN}✓ File unlocked for ${duration}s${NC}"
    log_action "temp-unlock" "$file" "Duration: ${duration}s"
}

#===============================================================================
# PROTECT COMMAND
#===============================================================================

guardian_protect() {
    local file="$1"
    
    if [ -z "$file" ]; then
        echo -e "${RED}❌ Usage: guardian protect <file>${NC}"
        return 1
    fi
    
    # Check user sovereignty
    if check_user_sovereignty "$file"; then
        echo -e "${RED}╔══════════════════════════════════════════════════════════╗${NC}"
        echo -e "${RED}║  🚨 USER SOVEREIGNTY VIOLATION                          ║${NC}"
        echo -e "${RED}╚══════════════════════════════════════════════════════════╝${NC}"
        echo ""
        echo -e "${RED}Cannot protect: $file${NC}"
        echo ""
        echo "This file is protected by USER SOVEREIGNTY."
        echo "Guardian cannot protect user shell configs or security files."
        echo ""
        return 1
    fi
    
    /usr/bin/sudo chattr +i "$file" && \
        echo -e "${GREEN}✓ Protected: $file${NC}" || \
        echo -e "${RED}✗ Failed to protect: $file${NC}"
    
    log_action "protect" "$file" "Manual protection"
}

#===============================================================================
# MAIN COMMAND DISPATCHER
#===============================================================================

case "${1:-}" in
    init)
        guardian_init
        ;;
    request)
        shift
        guardian_request "$@"
        ;;
    approve)
        shift
        guardian_approve "$@"
        ;;
    pending)
        guardian_pending
        ;;
    status)
        guardian_status
        ;;
    log)
        shift
        guardian_log "$@"
        ;;
    temp-unlock)
        shift
        guardian_temp_unlock "$@"
        ;;
    protect)
        shift
        guardian_protect "$@"
        ;;
    emergency)
        /usr/bin/guardian-emergency "${2:-}" 2>/dev/null || \
            echo -e "${RED}Emergency override not installed. Run 'guardian init'${NC}"
        ;;
    version)
        echo "GUARDIAN v2.0 - Safe File Protection"
        ;;
    *)
        echo ""
        echo -e "${CYAN}GUARDIAN v2.0 - Safe File Protection for AI Agents${NC}"
        echo ""
        echo "Usage: guardian <command> [options]"
        echo ""
        echo "Commands:"
        echo "  init                    Initialize Guardian (run once)"
        echo "  status                  Show protection status"
        echo "  request <file> <reason> Request file edit (agents)"
        echo "  approve <id>            Approve request (users)"
        echo "  pending                 Show pending requests"
        echo "  temp-unlock <file>      Temporarily unlock file"
        echo "  protect <file>          Add protection to file"
        echo "  log [lines]             View activity log"
        echo "  emergency <cmd>         Emergency override"
        echo "  version                 Show version"
        echo ""
        echo -e "${GREEN}User Sovereignty:${NC}"
        echo "  User files (.bashrc, .profile, etc.) are NEVER protected."
        echo "  The human user ALWAYS has final control."
        echo ""
        echo -e "${YELLOW}Emergency:${NC}"
        echo "  guardian-emergency unlock-all"
        echo "  guardian-emergency recover-user-files"
        echo "  See: ~/GUARDIAN_RECOVERY_INSTRUCTIONS.txt"
        echo ""
        ;;
esac
