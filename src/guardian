#===============================================================================
# REQUEST SYSTEM
#===============================================================================

guardian_request() {
    local file="$1"
    local reason="$2"
    local agent="${3:-unknown_agent}"
    
    if [ -z "$file" ] || [ -z "$reason" ]; then
        echo -e "${RED}❌ Usage: guardian request <file> '<reason>'${NC}"
        return 1
    fi
    
    # Check user sovereignty
    if check_user_sovereignty "$file"; then
        echo -e "${GREEN}This file is user-sovereign and doesn't need Guardian approval.${NC}"
        echo -e "${GREEN}You can edit it directly.${NC}"
        return 0
    fi
    
    # Create request
    local timestamp=$(date '+%Y-%m-%d %H:%M:%S')
    local request_id=$(/usr/bin/openssl rand -hex 8)
    local request_file="$APPROVAL_QUEUE/${request_id}.request"
    
    # Use NLP system if available
    if [ -f "$GUARDIAN_DIR/guardian-nlp.py" ]; then
        python3 "$GUARDIAN_DIR/guardian-nlp.py" request "$file" "$reason" "$agent" 2>/dev/null
    else
        # Fallback: create simple request
        mkdir -p "$APPROVAL_QUEUE"
        cat > "$request_file" << EOF
REQUEST_ID: $request_id
FILE: $file
REASON: $reason
AGENT: $agent
STATUS: PENDING
TIMESTAMP: $timestamp
EOF
    fi
    
    echo ""
    echo -e "${CYAN}╔══════════════════════════════════════════════════════════╗${NC}"
    echo -e "${CYAN}║           🔐 GUARDIAN FILE EDIT REQUEST                  ║${NC}"
    echo -e "${CYAN}╚══════════════════════════════════════════════════════════╝${NC}"
    echo ""
    echo -e "${BLUE}📁 File:${NC} $file"
    echo -e "${BLUE}🤖 Agent:${NC} $agent"
    echo -e "${BLUE}📝 Reason:${NC} $reason"
    echo -e "${BLUE}🔑 Request ID:${NC} $request_id"
    echo ""
    echo -e "${YELLOW}Respond with 'approved' or 'denied' to this request.${NC}"
    echo ""
    
    log_action "request" "$file" "$reason"
}

#===============================================================================
# APPROVAL SYSTEM
#===============================================================================

guardian_approve() {
    local request_id="$1"
    
    if [ -z "$request_id" ]; then
        echo -e "${RED}❌ Usage: guardian approve <request_id>${NC}"
        guardian_pending
        return 1
    fi
    
    local request_file="$APPROVAL_QUEUE/${request_id}.request"
    
    if [ ! -f "$request_file" ]; then
        echo -e "${RED}❌ Request not found: $request_id${NC}"
        return 1
    fi
    
    # Read request
    local file=$(grep "^FILE:" "$request_file" | cut -d: -f2- | xargs)
    local reason=$(grep "^REASON:" "$request_file" | cut -d: -f2-)
    
    echo ""
    echo -e "${CYAN}╔══════════════════════════════════════════════════════════╗${NC}"
    echo -e "${CYAN}║               GUARDIAN - Approval Required               ║${NC}"
    echo -e "${CYAN}╚══════════════════════════════════════════════════════════╝${NC}"
    echo ""
    echo -e "${BLUE}File:${NC} $file"
    echo -e "${BLUE}Reason:${NC} $reason"
    echo ""
    
    # Interactive confirmation
    read -p "Approve this modification? (yes/no): " confirmation
    
    if [ "$confirmation" != "yes" ]; then
        echo -e "${RED}❌ Request DENIED${NC}"
        rm -f "$request_file"
        log_action "deny" "$file" "User denied"
        return 1
    fi
    
    # Check user sovereignty again (safety)
    if check_user_sovereignty "$file"; then
        echo -e "${YELLOW}⚠️  Note: This file is user-sovereign and doesn't need protection.${NC}"
    fi
    
    # Unlock file
    echo -e "${GREEN}✅ Request APPROVED${NC}"
    /usr/bin/sudo chattr -i "$file" 2>/dev/null
    
    # Track unlock
    if [ -f "$GUARDIAN_DIR/unlock-tracker.py" ]; then
        python3 "$GUARDIAN_DIR/unlock-tracker.py" add "$file" 300 2>/dev/null
    fi
    
    # Move to processed
    mv "$request_file" "$GUARDIAN_DIR/logs/"
    
    log_action "approve" "$file" "Approved"
    
    echo ""
    echo -e "${GREEN}File unlocked for 5 minutes.${NC}"
    echo -e "${BLUE}It will auto-relock after that.${NC}"
}

